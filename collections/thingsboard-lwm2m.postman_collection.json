          "id": "18872296-ae9b-435d-8053-747a487f4c0b",
          "name": "Get Lwm2m Bootstrap SecurityInfo (getLwm2mBootstrapSecurityInfo)",
          "request": {
            "name": "Get Lwm2m Bootstrap SecurityInfo (getLwm2mBootstrapSecurityInfo)",
            "description": {
              "content": "Get the Lwm2m Bootstrap SecurityInfo object (of the current server) based on the provided isBootstrapServer parameter. If isBootstrapServer == true, get the parameters of the current Bootstrap Server. If isBootstrapServer == false, get the parameters of the current Lwm2m Server. Used for client settings when starting the client in Bootstrap mode. \n\nAvailable for users with 'TENANT_ADMIN' or 'CUSTOMER_USER' authority.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "lwm2m",
                "deviceProfile",
                "bootstrap",
                ":isBootstrapServer"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<boolean>",
                  "key": "isBootstrapServer",
                  "description": "(Required) A Boolean value representing the Server SecurityInfo for future Bootstrap client mode settings. Values: 'true' for Bootstrap Server; 'false' for Lwm2m Server. "
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
