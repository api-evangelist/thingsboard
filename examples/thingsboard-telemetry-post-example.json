{
  "description": "Post a telemetry batch into ThingsBoard against a device.",
  "request": {
    "method": "POST",
    "url": "https://demo.thingsboard.io/api/plugins/telemetry/DEVICE/{deviceId}/timeseries/ANY",
    "headers": {
      "X-Authorization": "Bearer <JWT>",
      "Content-Type": "application/json"
    },
    "body": {
      "ts": 1715000000000,
      "values": {
        "temperature": 22.5,
        "humidity": 41.2,
        "battery": 87
      }
    }
  },
  "response": {
    "status": 200,
    "body": ""
  }
}
